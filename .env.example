# ============================================================================
# socialbotic-site — environment variables (early-access subscribe)
# Copy to .env.local for local dev; set the same keys in Vercel → Production.
# ============================================================================

# ── Supabase (required) ─────────────────────────────────────────────────────
# The EXISTING socialbotic Supabase project, accessed server-side via the REST
# API with the SERVICE key (bypasses RLS) — same pattern/names as the project's
# publish/generate scripts. The `subscribers` table is managed in Supabase
# directly: email (unique), source, created_at, unsubscribed_at (RLS enabled,
# granted to service_role). No connection string or migrations here.
SUPABASE_URL="https://uiruyvjupprfmdzfbbcu.supabase.co"
SUPABASE_SERVICE_KEY=""   # sensitive — never commit; set in Vercel only

# ── Transactional email (confirmation) ──────────────────────────────────────
# Resend (https://resend.com). Sends the "You're on the early-access list"
# confirmation from the verified socialbotic.com domain. Without the key the
# confirmation is skipped silently and the subscribe still succeeds.
RESEND_API_KEY=""
RESEND_FROM="Socialbotic <hello@socialbotic.com>"

# ── Admin endpoint ──────────────────────────────────────────────────────────
# Shared secret for GET /api/admin/subscribers. Pass it as an `x-admin-token`
# header or `?token=` query param. Use a long random value.
SUBSCRIBE_ADMIN_TOKEN=""
